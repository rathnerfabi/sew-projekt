<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="viewctrl.ErgebnisController"
      prefWidth="700.0" prefHeight="500.0"
      spacing="20.0" alignment="CENTER">

    <padding>
        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
    </padding>

    <Label fx:id="lblKategorie" text=""
           style="-fx-font-size: 14px; -fx-text-fill: #555;"/>

    <Label fx:id="lblTitel" text="Spiel zu Ende"
           style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

    <Label fx:id="lblGewinn" text=""
           style="-fx-font-size: 22px;"/>

    <Label fx:id="lblNachricht" text=""
           wrapText="true"
           style="-fx-font-size: 14px;"/>

    <Button text="Zurück zum Menü" onAction="#doZurueck"
            prefWidth="220.0" prefHeight="40.0"/>

</VBox>